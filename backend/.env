# AI Portal V2 - Local Development Configuration
# OpenCode / OpenWork use real local endpoints.
# Auth remains dev mock-login unless you fill real SSO settings below.

# ============= Environment =============
ENV=dev

# ============= Server =============
PORT=8000
HOST=0.0.0.0
RELOAD=true

# ============= Auth (Dev Mock Login) =============
ENABLE_MOCK_LOGIN=true
COOKIE_SECURE=false
SESSION_MAX_AGE_SEC=86400

# Real SSO: fill these fields and optionally disable mock login
SSO_AUTHORIZE_URL=
SSO_TOKEN_URL=
SSO_CLIENT_ID=
SSO_CLIENT_SECRET=
SSO_REDIRECT_URI=http://localhost:8000/api/auth/callback
SSO_JWKS_URL=

# ============= OpenCode =============
OPENCODE_BASE_URL=http://127.0.0.1:4096
OPENCODE_USERNAME=opencode
OPENCODE_PASSWORD=

# ============= OpenWork =============
OPENWORK_BASE_URL=http://127.0.0.1:8787
OPENWORK_TOKEN=

# ============= Portal =============
PORTAL_NAME=AI Portal (Dev Mode)
RESOURCES_PATH=config/resources.generated.json

# ============= Logging =============
LOG_LEVEL=INFO

# ============= Deprecated (ignored) =============
USE_REDIS=false
