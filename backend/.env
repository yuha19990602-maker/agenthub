# AI Portal V2 - Local Development Configuration with Fake SSO
# This configuration enables testing without real SSO infrastructure

# ============= Environment =============
ENV=dev

# ============= Server =============
PORT=8000
HOST=0.0.0.0
RELOAD=true

# ============= Auth (Fake SSO Mode) =============
# SSO endpoints are empty - this triggers Fake SSO mode automatically
# Any authorization code will be accepted
ENABLE_MOCK_LOGIN=true
COOKIE_SECURE=false
SESSION_MAX_AGE_SEC=86400

# SSO URLs (left empty to enable Fake SSO)
SSO_AUTHORIZE_URL=
SSO_TOKEN_URL=
SSO_CLIENT_ID=fake-client-id
SSO_CLIENT_SECRET=fake-client-secret
SSO_REDIRECT_URI=http://localhost:8000/api/auth/callback
SSO_JWKS_URL=

# ============= OpenCode =============
OPENCODE_BASE_URL=http://127.0.0.1:4096
OPENCODE_USERNAME=opencode
OPENCODE_PASSWORD=

# ============= OpenWork =============
OPENWORK_BASE_URL=http://127.0.0.1:8787
OPENWORK_TOKEN=

# ============= Portal =============
PORTAL_NAME=AI Portal (Dev Mode)
RESOURCES_PATH=config/resources.generated.json

# ============= Logging =============
LOG_LEVEL=INFO

# ============= Deprecated (ignored) =============
USE_REDIS=false
