# AI Portal V2 环境配置示例
# 复制此文件为 .env 并修改相应的值
# 
# V2 重大变更：
# - 鉴权：从 JWT Cookie 改为 SSO OAuth2 + 本地 Session
# - 存储：Redis 已弃用，固定使用内存存储
# - 新增：OpenAI Compatible v1 资源类型支持

# ============= 环境配置 =============
# dev: 开发环境（允许 mock 登录）
# prod: 生产环境（强制 SSO）
ENV=dev

# ============= 服务器配置 =============
PORT=8000
HOST=0.0.0.0
RELOAD=true

# ============= 认证配置 (V2) =============
# Mock 登录（仅开发环境）
ENABLE_MOCK_LOGIN=true

# Cookie 安全（生产环境必须为 true）
COOKIE_SECURE=false

# 会话有效期（秒）
SESSION_MAX_AGE_SEC=86400

# ============= SSO OAuth2 配置 =============
# SSO 授权端点（登录页面 URL）
SSO_AUTHORIZE_URL=

# SSO Token 端点（用于 code 换 token）
SSO_TOKEN_URL=

# SSO Client ID
SSO_CLIENT_ID=

# SSO Client Secret
SSO_CLIENT_SECRET=

# 回调地址（必须和 SSO 配置一致）
SSO_REDIRECT_URI=http://localhost:8000/api/auth/callback

# JWKS 端点（用于验证 JWT）
SSO_JWKS_URL=

# ============= OpenCode 配置 =============
OPENCODE_BASE_URL=http://127.0.0.1:4096
OPENCODE_USERNAME=opencode
OPENCODE_PASSWORD=your-opencode-password

# ============= OpenWork 配置 =============
OPENWORK_BASE_URL=http://127.0.0.1:8787
OPENWORK_TOKEN=your-openwork-token

# ============= Portal 配置 =============
PORTAL_NAME=AI Portal
RESOURCES_PATH=config/resources.generated.json

# ============= 日志配置 =============
LOG_LEVEL=INFO
# LOG_LEVEL=DEBUG  # 开发时使用 DEBUG 级别

# ============= 已弃用配置（保留兼容性）=============
# Redis 存储已弃用，以下配置被忽略
# USE_REDIS=false
# REDIS_URL=redis://localhost:6379/0

# JWT 配置已弃用（改为本地 Session）
# JWT_SECRET=your-secret-key
# JWT_ALGORITHM=HS256
# JWT_EXPIRATION_HOURS=24
# AUTH_MOCK_FALLBACK_ENABLED=false

# ============= 前端配置 (frontend/.env) =============
# VITE_API_BASE_URL=http://localhost:8000
# VITE_APP_NAME=AI Portal
